# Rename this file to `.env` and fill in the correct URLs
# The URLs must be direct download links to your Excel files so the application can read them.

# Example: https://<your-share>.sharepoint.com/:x:/r/sites/.../Budget.xlsx?download=1
BUDGET_SOURCE_URL=

# Example: https://<your-share>.sharepoint.com/:x:/r/sites/.../Scope.xlsx?download=1
SCOPE_SOURCE_URL=

# Optionally override the cache TTL in seconds (default 300). Set to a lower value if you need more frequent refresh.
CACHE_TTL=300
